generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  patient
  doctor
  lab_tech
  lab_admin
  hospital_staff
  admin
  super_admin

  @@map("user_role")
}

enum UserSource {
  self_signup
  hospital
  lab
  admin_created
  imported

  @@map("user_source")
}

enum UserStatus {
  pending
  active
  inactive
  blocked

  @@map("user_status")
}

enum OtpPurpose {
  signup
  login

  @@map("otp_purpose")
}

model User {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mobile           String     @unique @db.VarChar
  email            String?    @unique @db.VarChar
  fullName         String?    @map("full_name") @db.VarChar
  role             UserRole   @default(patient)
  source           UserSource
  status           UserStatus
  mobileVerifiedAt DateTime?  @map("mobile_verified_at")
  deletedAt        DateTime?  @map("deleted_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  refreshTokens     RefreshToken[]
  doctorProfile     DoctorProfile?
  auditLogs         AuditLog[]
  reviewedDocuments DoctorDocument[] @relation("DocumentReviewer")
  verifiedDoctors   DoctorProfile[]  @relation("DoctorVerifier")

  @@map("users")
}

model OtpVerification {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mobile     String     @db.VarChar
  otpHash    String     @map("otp_hash") @db.VarChar
  purpose    OtpPurpose
  expiresAt  DateTime   @map("expires_at")
  attempts   Int        @default(0)
  verifiedAt DateTime?  @map("verified_at")
  createdAt  DateTime   @default(now()) @map("created_at")

  @@index([mobile])
  @@map("otp_verifications")
}

model RefreshToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @map("token_hash") @db.VarChar
  deviceInfo String?   @map("device_info") @db.VarChar
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ──────────────────────────────────────────────────
// Doctor Onboarding & Verification Enums
// ──────────────────────────────────────────────────

enum DoctorVerificationStatus {
  profile_incomplete
  under_review
  verified
  rejected
  suspended

  @@map("doctor_verification_status")
}

enum DoctorDocumentType {
  medical_degree
  medical_council_registration
  government_id
  profile_photo
  additional_certification

  @@map("doctor_document_type")
}

enum DocumentVerificationStatus {
  pending_review
  approved
  rejected

  @@map("document_verification_status")
}

enum AuditAction {
  doctor_profile_approved
  doctor_profile_rejected
  doctor_profile_suspended
  doctor_profile_resubmission_requested
  document_approved
  document_rejected
  user_blocked
  user_unblocked
  user_role_changed

  @@map("audit_action")
}

// ──────────────────────────────────────────────────
// DoctorProfile — Doctor-specific professional data
// ──────────────────────────────────────────────────

model DoctorProfile {
  id                    String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String                   @unique @map("user_id") @db.Uuid
  registrationNumber    String?                  @unique @map("registration_number") @db.VarChar
  qualification         String?                  @db.VarChar
  specialization        String?                  @db.VarChar
  yearsOfExperience     Int?                     @map("years_of_experience")
  consultationFee       Decimal?                 @map("consultation_fee") @db.Decimal(10, 2)
  currentHospital       String?                  @map("current_hospital") @db.VarChar
  bio                   String?                  @db.Text
  verificationStatus    DoctorVerificationStatus @default(profile_incomplete) @map("verification_status")
  verifiedAt            DateTime?                @map("verified_at")
  verifiedById          String?                  @map("verified_by_id") @db.Uuid
  submittedAt           DateTime?                @map("submitted_at")
  rejectionReason       String?                  @map("rejection_reason") @db.Text
  suspensionReason      String?                  @map("suspension_reason") @db.Text
  profileLocked         Boolean                  @default(false) @map("profile_locked")
  declarationAccepted   Boolean                  @default(false) @map("declaration_accepted")
  declarationAcceptedAt DateTime?                @map("declaration_accepted_at")
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @updatedAt @map("updated_at")

  user       User             @relation(fields: [userId], references: [id])
  verifiedBy User?            @relation("DoctorVerifier", fields: [verifiedById], references: [id])
  documents  DoctorDocument[]

  @@index([verificationStatus])
  @@index([specialization])
  @@index([verifiedById])
  @@map("doctor_profiles")
}

// ──────────────────────────────────────────────────
// DoctorDocument — Uploaded verification documents
// ──────────────────────────────────────────────────

model DoctorDocument {
  id                 String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  doctorProfileId    String                     @map("doctor_profile_id") @db.Uuid
  documentType       DoctorDocumentType         @map("document_type")
  fileUrl            String                     @map("file_url") @db.VarChar
  originalFileName   String?                    @map("original_file_name") @db.VarChar
  mimeType           String?                    @map("mime_type") @db.VarChar(100)
  fileSizeBytes      Int?                       @map("file_size_bytes")
  verificationStatus DocumentVerificationStatus @default(pending_review) @map("verification_status")
  rejectionReason    String?                    @map("rejection_reason") @db.Text
  uploadedAt         DateTime                   @default(now()) @map("uploaded_at")
  reviewedAt         DateTime?                  @map("reviewed_at")
  reviewedById       String?                    @map("reviewed_by_id") @db.Uuid

  doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  reviewedBy    User?         @relation("DocumentReviewer", fields: [reviewedById], references: [id])

  @@unique([doctorProfileId, documentType], map: "doctor_documents_profile_type_unique")
  @@index([doctorProfileId])
  @@index([documentType])
  @@index([verificationStatus])
  @@index([reviewedById])
  @@map("doctor_documents")
}

// ──────────────────────────────────────────────────
// AuditLog — Admin action compliance trail
// ──────────────────────────────────────────────────

model AuditLog {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId          String      @map("admin_id") @db.Uuid
  action           AuditAction
  targetEntityType String      @map("target_entity_type") @db.VarChar(50)
  targetEntityId   String      @map("target_entity_id") @db.Uuid
  reason           String?     @db.Text
  metadata         Json?
  createdAt        DateTime    @default(now()) @map("created_at")

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action])
  @@index([targetEntityType, targetEntityId])
  @@index([createdAt])
  @@map("audit_logs")
}
